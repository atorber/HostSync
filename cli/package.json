{
  "name": "hostsync",
  "version": "0.1.0",
  "description": "主机感知的配置文件同步工具 — 一键同步到 S3 兼容对象存储，按 hostname 自动分层，内置 Web UI",
  "type": "commonjs",
  "bin": {
    "hostsync": "dist/index.js"
  },
  "files": [
    "dist",
    "web-dist"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "s3",
    "config",
    "sync",
    "hostname",
    "backup",
    "cli",
    "object-storage"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/luyuchao/HostSync.git",
    "directory": "cli"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.888.0",
    "@aws-sdk/lib-storage": "^3.888.0",
    "commander": "^14.0.0",
    "express": "^5.1.0",
    "ignore": "^7.0.5",
    "mime-types": "^3.0.1",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/mime-types": "^2.1.4",
    "@types/node": "^22.13.5",
    "tsup": "^8.5.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
